package agent.rules

import com.wcdk.ai.aiagenttest.agent.pipeline.PerceptionResult;
import com.wcdk.ai.aiagenttest.agent.rules.InferenceResult;
import com.wcdk.ai.aiagenttest.agent.rules.DecisionResult;

global java.util.concurrent.atomic.AtomicReference decision;

rule "safe reply for risky request"
  salience 100
when
  $p: PerceptionResult(risky == true)
then
  decision.set(new DecisionResult(
    "SAFE_REPLY",
    "chat",
    "用户请求可能涉及高风险操作。请先解释风险，不要直接执行破坏性操作，并要求用户明确确认。",
    false
  ));
end

rule "execute task request"
  salience 80
when
  $p: PerceptionResult(command == true)
then
  decision.set(new DecisionResult(
    "EXECUTE_TASK",
    "chat",
    "用户需要执行型结果。请给出具体步骤、代码或明确的操作结果，避免空泛解释。",
    true
  ));
end

rule "execute task inferred"
  salience 70
when
  $i: InferenceResult(intent == "EXECUTE_TASK")
then
  decision.set(new DecisionResult(
    "EXECUTE_TASK",
    "chat",
    "模型判断这是执行型任务。请输出具体、可执行的内容。",
    true
  ));
end

rule "answer question request"
  salience 60
when
  $p: PerceptionResult(question == true)
then
  decision.set(new DecisionResult(
    "ANSWER_QUESTION",
    "chat",
    "用户正在提问。请先直接回答结论，再给必要依据。",
    true
  ));
end

rule "answer question inferred"
  salience 50
when
  $i: InferenceResult(intent == "ANSWER_QUESTION")
then
  decision.set(new DecisionResult(
    "ANSWER_QUESTION",
    "chat",
    "模型判断这是问题咨询。请直接回答，并补充必要上下文。",
    true
  ));
end
