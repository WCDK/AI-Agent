package agent.rules

import com.wcdk.ai.agent.rules.InferenceResult
import com.wcdk.ai.agent.rules.DecisionResult

global java.util.concurrent.atomic.AtomicReference decision;

rule "intent draw image"
  salience 80
  activation-group "decision"
when
  $i: InferenceResult(intent == "DRAW_IMAGE")
then
  decision.set(new DecisionResult(
    "GENERATE_IMAGE",
    "image",
    "用户意图是图画/图片生成。请根据用户描述生成可用于图像模型的清晰提示词。",
    true
  ));
end

rule "intent execute task"
  salience 70
  activation-group "decision"
when
  $i: InferenceResult(intent == "EXECUTE_TASK")
then
  decision.set(new DecisionResult(
    "EXECUTE_TASK",
    "chat",
    "模型判断这是执行型任务。请输出具体、可执行的内容。",
    true
  ));
end

rule "intent answer question"
  salience 60
  activation-group "decision"
when
  $i: InferenceResult(intent == "ANSWER_QUESTION")
then
  decision.set(new DecisionResult(
    "ANSWER_QUESTION",
    "chat",
    "模型判断这是问题咨询。请直接回答，并补充必要上下文。",
    true
  ));
end
